// Inline struct return values

io :: import "std/io"

make_point :: fn(x: i32, y: i32) struct { x: i32, y: i32 } {
    ret struct { x: i32, y: i32 } { x: x, y: y }
}

main :: fn() {
    io.println("=== Inline Structs ===")

    point := make_point(3, 4)
    io.println("point = ({}, {})", point.x, point.y)
}
