io :: import "std/io"

Value :: union {
    int_val: i32
    float_val: f64
}

main :: fn() {
    int_value := Value{int_val: 42}
    float_value := Value{float_val: 3.5}

    io.println("=== Unions ===")
    io.println("int: {}", int_value.int_val)
    io.println("float: {}", float_value.float_val)
}
