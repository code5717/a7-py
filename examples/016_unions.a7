// Union declaration status
//
// Union declarations lower in both backends. Runtime field construction and
// field access are still tracked separately, so this example is intentionally
// limited to declaration coverage.

io :: import "std/io"

Value :: union {
    int_val: i32
    float_val: f64
}

main :: fn() {
    io.println("=== Unions Status ===")
    io.println("Union type declaration lowers in both backends.")
    io.println("Runtime union field access is tracked separately.")
}
