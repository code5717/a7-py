// Memory management basics in A7

io :: import "std/io"

Box :: struct {
    value: i32
}

main :: fn() {
    io.println("=== Memory ===")

    value_box := new Box
    if value_box == nil {
        io.println("allocation failed")
        ret
    }
    defer del value_box

    value_box.value = 42
    io.println("heap value = {}", value_box.value)

    // Keep this example conservative and deterministic.
    io.println("memory example complete")
}
