// Fibonacci sequence

io :: import "std/io"

fib :: fn(n: usize) u64 {
    if n < 2 {
        ret cast(u64, n)
    }

    prev: u64 = 0
    acc: u64 = 1
    i: usize = 2

    while i <= n {
        next := prev + acc
        prev = acc
        acc = next
        i += 1
    }

    ret acc
}

main :: fn() {
    io.println("=== Fibonacci ===")

    i: usize = 0
    while i < 10 {
        io.println("fib({}) = {}", i, fib(i))
        i += 1
    }
}
